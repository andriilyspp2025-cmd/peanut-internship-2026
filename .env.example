# Environment: testnet | prod
ENVIRONMENT=prod

# Wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ADDRESS=0xYOUR_WALLET_ADDRESS

# RPC endpoints
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# Primary HTTP RPC used by the bot
RPC_URL=https://your-arbitrum-rpc
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# HTTP RPC Endpoints (for ChainClient, eth_call, eth_feehistory)
QN_HTTP_1=https://your-rpc-endpoint-1/
QN_HTTP_2=https://your-rpc-endpoint-2/
QN_HTTP_3=https://your-rpc-endpoint-3/
QN_HTTP_4=https://your-rpc-endpoint-4/
QN_HTTP_5=https://your-rpc-endpoint-5/

# WSS Endpoints (for MempoolMonitor, eth_subscribe)
# NOTE: WSS must match HTTP numbering for synchronized rotation
# When HTTP[1] receives 429 → both HTTP[2] and WSS[2] activate together
QN_WSS_1=wss://your-wss-endpoint-1/
QN_WSS_2=wss://your-wss-endpoint-2/
QN_WSS_3=wss://your-wss-endpoint-3/
QN_WSS_4=wss://your-wss-endpoint-4/
QN_WSS_5=wss://your-wss-endpoint-5/

# RPC Cache Configuration
RPC_CACHE_TTL_MS=300
GAS_CACHE_TTL_SECONDS=15

# Fallback WSS (legacy, preferred is QN_WSS_* list)
WSS_URL=wss://your-arbitrum-wss

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true

# Binance API
BINANCE_TESTNET_API_KEY=your_key_here
BINANCE_TESTNET_SECRET=your_secret_here
BINANCE_PROD_API_KEY=your_real_api_key_here
BINANCE_PROD_SECRET=your_real_secret_here

# Strategy params - Spread & Profitability
MIN_SPREAD_BPS=15
MIN_PROFIT_USD=0.20
MAX_TRADE_USD=10.0
MAX_POSITION_USD=50
MAX_OPEN_POSITIONS=2
MIN_OPEN_POSITION_USD=1
GAS_BUFFER_BPS=20
ENABLE_V2_POOLS=false

# Risk Management
MIN_SCORE_THRESHOLD=40.0
MAX_SPREAD_BPS=1000
MAX_DRAWDOWN_PCT=0.15
MAX_TRADES_PER_HOUR=20
MAX_CONSECUTIVE_LOSSES=5
MAX_SIGNAL_AGE_SECONDS=60
MAX_DAILY_LOSS_USD=10.0

# DEX Slippage Tolerances
DEX_SLIPPAGE_PCT=0.995
DEX_EMERGENCY_SLIPPAGE_PCT=0.05

# Uniswap V3 pool addresses (Arbitrum)
ETH_USDC_POOL_V3=0xC6962004f452bE9203591991D15f6b388e09E8D0
ARB_USDC_POOL_V3=0xA8328bf492Ba1b77aD6381b3f7567d942b000baF
GMX_USDC_POOL_V3=0xfc5A1A6EB076a2C7aD06eD22C90d7E710E35ad0a